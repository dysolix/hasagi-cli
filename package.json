{
  "name": "@hasagi/cli",
  "version": "0.9.9",
  "private": true,
  "description": "This package provides the 'hasagi' command-line interface",
  "bin": {
    "hasagi": "bin/index.js"
  },
  "scripts": {
    "build": "node scripts/prebuild.mjs && tsc && node scripts/postbuild.mjs",
    "check:package": "npm run build && publint ./dist",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "npm run test:typecheck && vitest run",
    "test:typecheck": "tsc -p tsconfig.test.json",
    "release": "npm run check:package && cd ./dist && npm publish --access public",
    "update": "npm i @hasagi/core@latest @hasagi/schema@latest"
  },
  "keywords": [
    "hasagi"
  ],
  "author": "dysolix",
  "license": "MIT",
  "dependencies": {
    "@hasagi/core": "^0.6.7",
    "@hasagi/schema": "^0.6.8",
    "yargs": "^17.7.2"
  },
  "type": "module",
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^20.19.43",
    "@types/yargs": "^17.0.24",
    "eslint": "^10.5.0",
    "publint": "^0.3.21",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dysolix/hasagi-cli.git"
  }
}
